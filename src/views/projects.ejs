<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>

    <section class="projects-intro">
        <h2>Upcoming Service Projects</h2>
        <p>Find volunteer opportunities in your community. Browse projects by our partner organizations.</p>
    </section>

    <% if (projects.length === 0) { %>
        <p class="projects-empty">No upcoming projects at the moment. Check back soon!</p>
    <% } else { %>
        <section class="projects-grid" aria-label="Upcoming service projects">
            <% projects.forEach(project => { %>
             
                <% const formattedDate = new Date(project.project_date + 'T00:00:00').toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }); %>
                <article class="project-card">
                    <header class="project-card__header">
                        <a href="project/<%= project.project_id %>">   <h3 class="project-card__title"><%= project.title %></h3>    </a>
                        <% if (project.name) { %>
                            <a href="organization/<%= project.organization_id%>"><span class="project-card__org"><%= project.name %></span></a>
                        <% } %>
                    </header>
                    <p class="project-card__description"><%= project.description %></p>
                    <footer class="project-card__meta">
                        <span class="project-card__meta-item"><%= project.location %></span>
                        <span class="project-card__meta-item"><%= formattedDate %></span>
                    </footer>
                </article>
        
            <% }); %>
        </section>
    <% } %>
</main>
<%- include('partials/footer') %>
