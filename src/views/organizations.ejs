<%- include('partials/header') %>
    <main>
        <h1>
            <%= title %>
        </h1>
        <p>Here are a few of our partner organizations:</p>
        <ul>
            <% organizations.forEach( org=>{ %>
            <a href="/organization/<%= org.organization_id %>">
                <li><img src="/images/<%=org.logo_filename%>" alt="<%=org.description%>"><strong><%=org.name%></strong>: <%= org.contact_email%></li>
            </a>
            <%});%>
        </ul>
        <% if (user && user.role_name === "admin") { %>
            <p><a href="/new-organization">Add New Organization</a></p>
        <% } %>
    </main>
    <%- include('partials/footer') %>