<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>
    <h2>Categories</h2>
    <% if (user && user.role_name === "admin") { %>
        <p><a href="/new-category">Add a new category</a></p>
    <% } %>
    <ul>
        <% categories.forEach(category => { %>
            <li>
                <%= category.name %>
                <% if (user && user.role_name === "admin") { %>
                    <a href="/edit-category/<%= category.category_id %>">Edit</a>
                <% } %>
            </li>
        <% }) %>
    </ul>
</main>
<%- include('partials/footer') %>